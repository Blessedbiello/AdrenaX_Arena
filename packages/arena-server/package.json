{
  "name": "arena-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:generate": "kysely-codegen --out-file src/db/types.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "kysely": "^0.27.4",
    "pg": "^8.13.0",
    "ioredis": "^5.4.1",
    "bullmq": "^5.13.0",
    "zod": "^3.23.8",
    "ws": "^8.18.0",
    "tweetnacl": "^1.0.3",
    "bs58": "^6.0.0",
    "p-retry": "^6.2.0",
    "p-queue": "^8.0.1",
    "satori": "^0.10.14",
    "@resvg/resvg-js": "^2.6.2",
    "discord.js": "^14.16.3",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.4.1",
    "dotenv": "^16.4.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "tsx": "^4.19.1",
    "vitest": "^2.1.3",
    "@types/express": "^5.0.0",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.12",
    "@types/cors": "^2.8.17",
    "@types/uuid": "^10.0.0",
    "kysely-codegen": "^0.16.8"
  }
}
